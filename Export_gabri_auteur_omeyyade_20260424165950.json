:"2-1"},{"dty_ID":3,"value":"Il retourna \u00e0 Bagdad apr\u00e8s moins de deux ans d'absence et y passa huit ann\u00e9es suppl\u00e9mentaires, dont une p\u00e9riode en tant que tuteur de l'un des fils du vizir du calife al-Mutawakkil, \u02bfUbayd All\u0101h b. Ya\u1e25y\u0101 b. \u1e34h\u0332\u0101\u1e33\u0101n, donc \u00e0 un moment donn\u00e9 entre 244\/858-9 et 248\/862.","fieldName":"Short description","fieldType":"blocktext","conceptID":"2-3"},{"dty_ID":10,"value":"0839","fieldName":"Birth date","fieldType":"date","conceptID":"2-10"},{"dty_ID":20,"value":"414","termLabel":"Male","termConceptID":"2-414","fieldName":"Gender","fieldType":"enum","conceptID":"2-20"},{"dty_ID":134,"value":{"id":"24","type":"12","title":"Tabaristan","hhash":null},"fieldName":"Place of birth","fieldType":"resource","conceptID":"2-134"}],"rec_RecTypeName":"Person","rec_RecTypeConceptID":"2-10"},{"rec_ID":"24","rec_RecTypeID":"12","rec_Title":"Tabaristan","rec_URL":null,"rec_ScratchPad":"","rec_OwnerUGrpID":"0","rec_NonOwnerVisibility":"viewable","rec_URLLastVerified":null,"rec_URLErrorMessage":null,"rec_Added":"2026-04-24 15:00:59","rec_Modified":"2026-04-24 15:14:40","rec_AddedByUGrpID":"2","rec_Hash":null,"rec_FlagTemporary":"0","details":[{"dty_ID":1,"value":"Tabaristan","fieldName":"Place name","fieldType":"freetext","conceptID":"2-1"},{"dty_ID":26,"value":"167","termLabel":"Iran","termConceptID":"2-167","fieldName":"Country","fieldType":"enum","conceptID":"2-26"},{"dty_ID":28,"value":{"geo":{"type":"p","wkt":"POINT(49.58182331 37.28553447)"}},"fieldName":"Location (mappable)","fieldType":"geo","conceptID":"2-28"},{"dty_ID":133,"value":"5319","termLabel":"Administrative.Province","termConceptID":"2-5319","fieldName":"Place type","fieldType":"enum","conceptID":"3-1068"},{"dty_ID":227,"value":"5342","termLabel":"1. High confidence","termConceptID":"1125-3340","fieldName":"Locational certainty","fieldType":"enum","conceptID":"1125-101"}],"rec_RecTypeName":"Place","rec_RecTypeConceptID":"3-1009"},{"rec_ID":"5","rec_RecTypeID":"10","rec_Title":"al-Bal\u0101dhur\u012b","rec_URL":null,"rec_ScratchPad":"","rec_OwnerUGrpID":"0","rec_NonOwnerVisibility":"viewable","rec_URLLastVerified":null,"rec_URLErrorMessage":null,"rec_Added":"2026-04-24 14:39:36","rec_Modified":"2026-04-24 15:14:22","rec_AddedByUGrpID":"2","rec_Hash":null,"rec_FlagTemporary":"0","details":[{"dty_ID":1,"value":"al-Bal\u0101dhur\u012b","fieldName":"Family name","fieldType":"freetext","conceptID":"2-1"},{"dty_ID":3,"value":"C'est un historien du IXe si\u00e8cle. Il \u00e9tait un compagnon privil\u00e9gi\u00e9 d'al-Mutawakkil ; son influence \u00e0 la cour semble s'\u00eatre poursuivie sous al-Musta\u02bf\u012bn, mais sa fortune a fortement d\u00e9clin\u00e9 sous al-Mu\u02bftamid.","fieldName":"Short description","fieldType":"blocktext","conceptID":"2-3"},{"dty_ID":10,"value":"0800-01-01","fieldName":"Birth date","fieldType":"date","conceptID":"2-10"},{"dty_ID":20,"value":"414","termLabel":"Male","termConceptID":"2-414","fieldName":"Gender","fieldType":"enum","conceptID":"2-20"},{"dty_ID":134,"value":{"id":"22","type":"12","title":"Bagdad","hhash":null},"fieldName":"Place of birth","fieldType":"resource","conceptID":"2-134"}],"rec_RecTypeName":"Person","rec_RecTypeConceptID":"2-10"},{"rec_ID":"4","rec_RecTypeID":"10","rec_Title":"Ibn 'Abd al-\u1e24akam","rec_URL":null,"rec_ScratchPad":"","rec_OwnerUGrpID":"0","rec_NonOwnerVisibility":"viewable","rec_URLLastVerified":null,"rec_URLErrorMessage":null,"rec_Added":"2026-04-24 14:37:53","rec_Modified":"2026-04-24 15:13:53","rec_AddedByUGrpID":"2","rec_Hash":null,"rec_FlagTemporary":"0","details":[{"dty_ID":1,"value":"Ibn 'Abd al-\u1e24akam","fieldName":"Family name","fieldType":"freetext","conceptID":"2-1"},{"dty_ID":3,"value":"Historien du IXe si\u00e8cle. Il s'agit du fils et des quatre petits-fils d'\u02bfAbd al-\u1e24akam (d\u00e9c\u00e9d\u00e9 en 171\/787-88), issu d'une riche et influente famille de juristes et d'historiens de l'\u00c9gypte du IIIe\/IXe si\u00e8cle. Les Ban\u016b \u02bfAbd al-\u1e24akam furent parmi ceux qui introduisirent le malikisme en \u00c9gypte. De ce fait, ils subirent des pers\u00e9cutions durant la Mu\u02bftazil\u012bmi\u1e25na en 227\/842, et en 237\/851, ils furent accus\u00e9s, entre autres, d'avoir d\u00e9tourn\u00e9 les biens confisqu\u00e9s \u00e0 un ancien haut fonctionnaire, biens que le gouvernement central revendiquait. (Il s'agit du 4\u00e8me fils.)","fieldName":"Short description","fieldType":"blocktext","conceptID":"2-3"},{"dty_ID":10,"value":"0788-01-13","fieldName":"Birth date","fieldType":"date","conceptID":"2-10"},{"dty_ID":20,"value":"414","termLabel":"Male","termConceptID":"2-414","fieldName":"Gender","fieldType":"enum","conceptID":"2-20"},{"dty_ID":134,"value":{"id":"25","type":"12","title":"Egypte","hhash":null},"fieldName":"Place of birth","fieldType":"resource","conceptID":"2-134"}],"rec_RecTypeName":"Person","rec_RecTypeConceptID":"2-10"},{"rec_ID":"25","rec_RecTypeID":"12","rec_Title":"Egypte","rec_URL":null,"rec_ScratchPad":"","rec_OwnerUGrpID":"0","rec_NonOwnerVisibility":"viewable","rec_URLLastVerified":null,"rec_URLErrorMessage":null,"rec_Added":"2026-04-24 15:02:12","rec_Modified":"2026-04-24 15:13:53","rec_AddedByUGrpID":"2","rec_Hash":null,"rec_FlagTemporary":"0","details":[{"dty_ID":1,"value":"Egypte","fieldName":"Place name","fieldType":"freetext","conceptID":"2-1"},{"dty_ID":26,"value":"259","termLabel":"Egypt","termCode":"EG","termConceptID":"2-259","fieldName":"Country","fieldType":"enum","conceptID":"2-26"},{"dty_ID":28,"value":{"geo":{"type":"p","wkt":"POINT(30.86308746 29.94348564)"}},"fieldName":"Location (mappable)","fieldType":"geo","conceptID":"2-28"},{"dty_ID":133,"value":"5317","termLabel":"Administrative.Country","termConceptID":"2-5317","fieldName":"Place type","fieldType":"enum","conceptID":"3-1068"},{"dty_ID":227,"value":"5342","termLabel":"1. High confidence","termConceptID":"1125-3340","fieldName":"Locational certainty"